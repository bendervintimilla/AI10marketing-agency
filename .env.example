# ==========================================
# Marketing Agency Monorepo Environment Variables
# ==========================================

# ------------------------------------------
# Database & Cache (packages/db & apps/api)
# ------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agency_db?schema=public"
REDIS_URL="redis://localhost:6379"

# ------------------------------------------
# Auth / JWT (apps/api)
# ------------------------------------------
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-strong-random-secret"

# ------------------------------------------
# Storage (MinIO local dev / AWS S3 in prod)
# ------------------------------------------
AWS_ACCESS_KEY_ID="minioadmin"
AWS_SECRET_ACCESS_KEY="minioadmin"
AWS_REGION="us-east-1"
AWS_S3_BUCKET_NAME="media-assets"
AWS_S3_ENDPOINT="http://localhost:9000"
AWS_S3_PUBLIC_URL="http://localhost:9000"

# ------------------------------------------
# AI Services
# ------------------------------------------
GEMINI_API_KEY="your_gemini_api_key"
VEO_API_KEY="your_veo_api_key"

# ------------------------------------------
# OAuth Login (Sign in with Google / Meta)
# ------------------------------------------
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:3001/auth/google/callback"
META_LOGIN_REDIRECT_URI="http://localhost:3001/auth/meta/callback"

# Frontend URL for OAuth callback redirects
FRONTEND_URL="http://localhost:3000"

# ------------------------------------------
# Social Media Platforms: Meta (Instagram + Facebook) — Publishing
# ------------------------------------------
META_APP_ID="your_meta_app_id"
META_APP_SECRET="your_meta_app_secret"
META_REDIRECT_URI="http://localhost:3001/publish/callback/instagram"

# Social Media Platforms: TikTok
TIKTOK_CLIENT_KEY="your_tiktok_client_key"
TIKTOK_CLIENT_SECRET="your_tiktok_client_secret"
TIKTOK_REDIRECT_URI="http://localhost:3001/publish/callback/tiktok"

# Token Encryption (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
TOKEN_ENCRYPTION_KEY="your_64_char_hex_key_here"

# ------------------------------------------
# Payments (Stripe) — leave blank to disable billing features
# ------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ------------------------------------------
# AI Brain & Worker
# ------------------------------------------
WORKER_SECRET="change-me-random-secret"
API_URL="http://localhost:3001"
AGENT_COPY_URL="http://localhost:3001"
AGENT_GENERATION_URL="http://localhost:3001"
AGENT_PUBLISH_URL="http://localhost:3001"
STRIPE_PRICE_ID_PRO="price_your_pro_price_id"
STRIPE_PRICE_ID_ENTERPRISE="price_your_enterprise_price_id"

# ------------------------------------------
# Web App (Next.js public vars)
# ------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
